---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Post AI - Managed PostgreSQL for the Edge">
  <!-- Nav -->
  <nav class="border-b border-gray-800 bg-surface/80 backdrop-blur-sm sticky top-0 z-50">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="flex items-center gap-2">
        <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center font-bold text-sm">P</div>
        <span class="text-xl font-bold">Post AI</span>
      </div>
      <div class="flex items-center gap-6 text-sm text-gray-400">
        <a href="#features" class="hover:text-white transition-colors">Features</a>
        <a href="#why" class="hover:text-white transition-colors">Why Post AI</a>
        <a href="#code" class="hover:text-white transition-colors">Example</a>
        <a href="/docs" class="px-4 py-2 bg-primary hover:bg-primary/80 text-white rounded-lg transition-colors font-medium">Get Started</a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 py-24 text-center">
    <div class="inline-block px-4 py-1.5 bg-primary/10 border border-primary/20 rounded-full text-primary text-sm font-medium mb-6">
      Managed PostgreSQL
    </div>
    <h1 class="text-5xl md:text-6xl font-bold mb-6 leading-tight">
      Post AI
      <span class="block text-accent">Managed PostgreSQL for the Edge</span>
    </h1>
    <p class="text-xl text-gray-400 max-w-2xl mx-auto mb-10">
      ACID transactions. Financial-grade. Global via Cloudflare Hyperdrive.
    </p>
    <div class="flex gap-4 justify-center">
      <a href="/docs" class="px-8 py-3 bg-primary hover:bg-primary/80 text-white rounded-lg transition-colors font-medium text-lg">
        Get Started
      </a>
      <a href="#code" class="px-8 py-3 border border-gray-700 hover:border-gray-500 text-gray-300 rounded-lg transition-colors font-medium text-lg">
        See Example
      </a>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="max-w-6xl mx-auto px-6 py-20">
    <h2 class="text-3xl font-bold text-center mb-4">Features</h2>
    <p class="text-gray-400 text-center mb-12 max-w-xl mx-auto">Everything you need for financial-grade data at the edge.</p>

    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-card rounded-xl p-6 border border-gray-800 hover:border-primary/40 transition-colors">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-4 text-primary text-lg">&#x1f512;</div>
        <h3 class="text-lg font-semibold mb-2">Real ACID Transactions</h3>
        <p class="text-gray-400 text-sm">Full PostgreSQL ACID compliance. BEGIN, COMMIT, ROLLBACK with serializable isolation when you need it.</p>
      </div>

      <div class="bg-card rounded-xl p-6 border border-gray-800 hover:border-primary/40 transition-colors">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-4 text-primary text-lg">&#x1f4b0;</div>
        <h3 class="text-lg font-semibold mb-2">BIGINT Money Type</h3>
        <p class="text-gray-400 text-sm">Store money as integer cents. No floating-point errors. No rounding surprises. Precision guaranteed.</p>
      </div>

      <div class="bg-card rounded-xl p-6 border border-gray-800 hover:border-primary/40 transition-colors">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-4 text-primary text-lg">&#x1f6e1;</div>
        <h3 class="text-lg font-semibold mb-2">Immutable Audit Trail</h3>
        <p class="text-gray-400 text-sm">SHA-256 chained audit log. Every change is recorded, hashed, and linked. Tamper-evident by design.</p>
      </div>

      <div class="bg-card rounded-xl p-6 border border-gray-800 hover:border-primary/40 transition-colors">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-4 text-primary text-lg">&#x2699;</div>
        <h3 class="text-lg font-semibold mb-2">Schema Migrations</h3>
        <p class="text-gray-400 text-sm">Version-controlled, sequential migrations. Apply, track, and roll forward with confidence.</p>
      </div>

      <div class="bg-card rounded-xl p-6 border border-gray-800 hover:border-primary/40 transition-colors">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-4 text-primary text-lg">&#x1f510;</div>
        <h3 class="text-lg font-semibold mb-2">Row-Level Security</h3>
        <p class="text-gray-400 text-sm">PostgreSQL RLS policies enforced at the database level. Multi-tenant isolation built in.</p>
      </div>

      <div class="bg-card rounded-xl p-6 border border-gray-800 hover:border-primary/40 transition-colors">
        <div class="w-10 h-10 bg-primary/10 rounded-lg flex items-center justify-center mb-4 text-primary text-lg">&#x1f310;</div>
        <h3 class="text-lg font-semibold mb-2">Edge via Hyperdrive</h3>
        <p class="text-gray-400 text-sm">Cloudflare Hyperdrive connection pooling and caching. Sub-millisecond reads at 300+ global PoPs.</p>
      </div>
    </div>
  </section>

  <!-- Why Post AI -->
  <section id="why" class="bg-card/50 border-y border-gray-800">
    <div class="max-w-6xl mx-auto px-6 py-20">
      <h2 class="text-3xl font-bold text-center mb-4">Why Post AI</h2>
      <p class="text-gray-400 text-center mb-12 max-w-2xl mx-auto">
        Designed for fintech. PostgreSQL reliability with edge performance via Cloudflare Hyperdrive.
        No ORMs to fight. No eventual consistency to debug. Just SQL that works.
      </p>

      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <div class="flex gap-4">
          <div class="text-accent text-xl mt-1">&#x2713;</div>
          <div>
            <h3 class="font-semibold mb-1">Financial-grade precision</h3>
            <p class="text-gray-400 text-sm">BIGINT cents means $0.10 + $0.20 always equals $0.30. No IEEE 754 surprises.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-accent text-xl mt-1">&#x2713;</div>
          <div>
            <h3 class="font-semibold mb-1">Compliance-ready audit</h3>
            <p class="text-gray-400 text-sm">SHA-256 chained logs give you SOX/PCI-ready audit trails out of the box.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-accent text-xl mt-1">&#x2713;</div>
          <div>
            <h3 class="font-semibold mb-1">Global low-latency</h3>
            <p class="text-gray-400 text-sm">Hyperdrive caches and pools connections at the edge. Your users feel local speed.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="text-accent text-xl mt-1">&#x2713;</div>
          <div>
            <h3 class="font-semibold mb-1">Just PostgreSQL</h3>
            <p class="text-gray-400 text-sm">No proprietary query language. No lock-in. Standard SQL with standard tools.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Code Example -->
  <section id="code" class="max-w-6xl mx-auto px-6 py-20">
    <h2 class="text-3xl font-bold text-center mb-4">Transaction Example</h2>
    <p class="text-gray-400 text-center mb-12 max-w-xl mx-auto">Real ACID transactions with the Money type. Integer cents, never floats.</p>

    <div class="max-w-3xl mx-auto bg-gray-900 rounded-xl border border-gray-800 overflow-hidden">
      <div class="flex items-center gap-2 px-4 py-3 bg-gray-900 border-b border-gray-800">
        <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
        <span class="text-xs text-gray-500 ml-2">POST /transaction</span>
      </div>
      <pre class="p-6 text-sm overflow-x-auto"><code class="text-gray-300"><span class="text-accent">curl</span> -X POST https://post-ai.g-a-l-a-c-t-i-c.com/transaction \
  -H <span class="text-yellow-300">"Authorization: Bearer $API_KEY"</span> \
  -H <span class="text-yellow-300">"Content-Type: application/json"</span> \
  -d <span class="text-yellow-300">'{
  "statements": [
    {
      "sql": "INSERT INTO ledger (account_id, amount_cents, type) VALUES ($1, $2, $3)",
      "params": ["acc_123", 150000, "credit"]
    },
    {
      "sql": "UPDATE accounts SET balance_cents = balance_cents + $1 WHERE id = $2",
      "params": [150000, "acc_123"]
    }
  ]
}'</span>

<span class="text-gray-500">// Response</span>
{
  <span class="text-primary">"success"</span>: true,
  <span class="text-primary">"results"</span>: [
    { <span class="text-primary">"rowCount"</span>: 1 },
    { <span class="text-primary">"rowCount"</span>: 1 }
  ],
  <span class="text-primary">"transaction_id"</span>: <span class="text-yellow-300">"txn_8f3a2b..."</span>
}</code></pre>
    </div>
    <p class="text-center text-gray-500 text-sm mt-4">
      Amount is <code class="text-accent">150000</code> cents = <code class="text-accent">$1,500.00</code>. Integer math. Always exact.
    </p>
  </section>

  <!-- CTA -->
  <section class="max-w-6xl mx-auto px-6 py-20 text-center">
    <h2 class="text-3xl font-bold mb-4">Ready to build?</h2>
    <p class="text-gray-400 mb-8">Start with 500MB free. No credit card required.</p>
    <a href="/docs" class="inline-block px-8 py-3 bg-primary hover:bg-primary/80 text-white rounded-lg transition-colors font-medium text-lg">
      Get Started
    </a>
  </section>

  <!-- Footer -->
  <footer class="border-t border-gray-800 py-8">
    <div class="max-w-6xl mx-auto px-6 flex items-center justify-between text-sm text-gray-500">
      <span>Post AI - Managed PostgreSQL for the Edge</span>
      <span>API: <code class="text-gray-400">https://post-ai.g-a-l-a-c-t-i-c.com</code></span>
    </div>
  </footer>
</Layout>
